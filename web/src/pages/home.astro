---
import { getLiveCollection } from "astro:content";
import { subtitle, url, preview, images, readMore } from "../util/Format";
import Page from "../layouts/Page.astro";
import LinkIcon from "../components/LinkIcon.astro";

const { entries, error } = await getLiveCollection("posts");
if (error || !entries)
  return new Response("Failed to load posts", { status: 502 });

const posts = entries.map((e) => e.data);
const visible = posts.filter((post) => !post.hidden);
const selected = visible.slice(0, 20);

// Cache the rendered page at the edge; posts change rarely.
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
---

<Page title="Home">
  <div class="posts">
    {
      selected.map((item) => (
        <article>
          <h1>
            <a href={url(item)}>{item.title}</a>
          </h1>
          <p class="subtitle">
            {item.external_link && <LinkIcon />}
            {item.external_link && " "}
            {subtitle(item)}
          </p>
          <Fragment set:html={preview(item)} />
          {item.gallery && (
            <div class="image-grid">
              {images(item).map((image) => {
                return (
                  <a href={url(item)}>
                    <img src={image.src} alt={image.alt} />
                  </a>
                );
              })}
            </div>
          )}
          {readMore(item) && (
            <a class="read-more-button" href={url(item)}>
              <p>Read More &#8594;</p>
            </a>
          )}
        </article>
      ))
    }
  </div>
</Page>
