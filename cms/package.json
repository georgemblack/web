{
  "name": "cms",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run",
    "deploy": "pnpm run build && wrangler deploy",
    "dryrun": "pnpm run build && wrangler deploy --dry-run",
    "preview": "pnpm run build && vite preview",
    "typegen": "wrangler types -c ./wrangler.jsonc -c ../cms-db/wrangler.jsonc",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write"
  },
  "dependencies": {
    "@cloudflare/kumo": "^1.8.0",
    "@cloudflare/vite-plugin": "^1.25.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-router": "^1.162.9",
    "@tanstack/react-router-devtools": "^1.162.9",
    "@tanstack/react-router-ssr-query": "^1.162.9",
    "@tanstack/react-start": "^1.163.1",
    "@tanstack/router-plugin": "^1.162.9",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "marked": "^17.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.5.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.68.1"
  }
}
