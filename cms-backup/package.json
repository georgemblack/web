{
	"name": "cms-backup",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dryrun": "wrangler deploy --dry-run",
		"typegen": "wrangler types -c ./wrangler.jsonc -c ../web-db/wrangler.jsonc",
		"typecheck": "tsc --noEmit",
		"format": "prettier . --write"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"prettier": "^3.8.1",
		"typescript": "^5.5.2",
		"wrangler": "^4.71.0"
	}
}
