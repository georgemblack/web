{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cms-backup",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-19",
	"observability": {
		"enabled": true,
	},
	"triggers": {
		"crons": ["0 12 * * *"],
	},
	"services": [
		{
			"binding": "CMS_DB",
			"service": "cms-db",
			"remote": true,
		},
	],
	"r2_buckets": [
		{
			"binding": "BACKUP_BUCKET",
			"bucket_name": "cms-backups",
		},
	],
}
